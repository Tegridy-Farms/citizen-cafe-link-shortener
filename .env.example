# Local dev: copy to .env.local and fill in your values.
# Vercel production/preview/development: set these in the Vercel dashboard.
# CI (GitHub Actions): add as repository secrets under Settings → Secrets and variables → Actions.

# Neon Postgres pooled connection string (canonical var — never use POSTGRES_URL).
DATABASE_URL=

# Secret key compared server-side on POST /api/shorten (R-002).
# Must NOT have a NEXT_PUBLIC_ prefix — never shipped to the browser bundle.
SHORTEN_API_KEY=

# Base URL for generated short links (e.g. https://citizen-cafe-link-shortener.vercel.app).
# Swap to a custom domain here without any code changes (R-001).
APP_BASE_URL=
